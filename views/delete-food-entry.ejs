<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delete Food Entry</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
</head>

<body>
    <div class="container m-5 bg-light">
        <h1>Deleting Food Record</h1>
        <form method="POST">
            <div class="alert alert-danger fw-bold"> Are you sure you want to delete <%= foodEntry.foodName %> recorded
                    on <%= foodEntry.dateTime.toLocaleDateString() %> <%= foodEntry.dateTime.toLocaleTimeString() %>
            </div>
            <div>
                <input type="submit" value="Delete" class="btn btn-danger"/>
                <a href="/" class="btn btn-success">Cancel</a>
            </div>
        </form>
    </div>

</body>

</html>