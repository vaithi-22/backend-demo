<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CICO Tracker</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
</head>

<body>
     <div class="container m-5 bg-light">
        <h1>CICO Tracking List</h1>

        <div class="row">
            <div class="col-3">
                <%- include("search-form", {
                    tags, searchParams
                }) %>
            </div>
            <div class="col">
                <table class="table text-center">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Food Name</th>
                            <th>Calories</th>
                            <th>Meal</th>
                            <th>Tags</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for (let foodEntry of foodEntries) { %>
                            <tr>
                                <td>
                                    <%= foodEntry.dateTime.toLocaleDateString() %>
                                        <%= foodEntry.dateTime.toLocaleTimeString() %>
                                </td>
                                <td>
                                    <%= foodEntry.foodName %>
                                </td>
                                <td>
                                    <%= foodEntry.calories %>
                                </td>
                                <td>
                                    <%= foodEntry.meal %>
                                </td>
                                <td>
                                    <%- foodEntry.selectedTags?.split(",").map(t=> `<span
                                            class="badge bg-primary ms-1 me-1">${t}</span>`
                                        ).join("") %>
                                </td>
                                <td>
                                    <a class="btn btn-success btn-sm"
                                        href="food-entry/<%= foodEntry.id %>/edit">Edit</a>
                                    <a class="btn btn-danger btn-sm"
                                        href="food-entry/<%= foodEntry.id %>/delete">Delete</a>
                                </td>
                            </tr>
                            <% } %>

                    </tbody>
                </table>
                <a  href="/food-entry/create" class="btn btn-primary btn-sm mt-4">ADD FOOD</a>
            </div>
        </div>



    </div>


</body>

</html>